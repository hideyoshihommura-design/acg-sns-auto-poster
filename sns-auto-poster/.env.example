# ============================================================
# 必須: Vertex AI (Google Cloud)
# ============================================================
# GCPプロジェクトID（Cloud Runでは自動取得されるため省略可）
GCP_PROJECT_ID=your-gcp-project-id

# Vertex AIのリージョン（東京）
VERTEX_LOCATION=asia-northeast1

# 使用するGeminiモデル
VERTEX_MODEL=gemini-2.5-flash

# ============================================================
# SNS設定（投稿テーマ・スケジュール）
# ============================================================
# 投稿のサブテーマ（毎日変えると投稿内容にバリエーションが出る）
# 例：介護記録のAI活用、シフト管理効率化、助成金活用、ChatGPT研修
SNS_THEME=介護現場でのAI活用・業務効率化

# ビジネス・サービス名（投稿の主体）
BUSINESS_NAME=ホリエモンAI学校介護校

# 毎日AIで自動生成する時刻（24時間表記 HH:MM）
SCHEDULE_TIME=09:00

# Web UIのポート番号
WEB_PORT=5000

# 投稿履歴の保存先ディレクトリ
OUTPUT_DIR=./output

# ============================================================
# WordPress連携（必須: SNS自動投稿に使用）
# ============================================================
# WordPressサイトのURL（末尾スラッシュなし）
WP_SITE_URL=https://your-wordpress-site.com

# 対象カテゴリのスラッグ（例: news）空白で全記事対象
WP_NEWS_CATEGORY_SLUG=news

# 何時間以内の新着記事をチェックするか（デフォルト: 48時間）
WP_CHECK_HOURS=48

# ============================================================
# X (Twitter) API認証情報
# https://developer.twitter.com/en/portal/dashboard
# ============================================================
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret

# ============================================================
# Meta (Facebook / Instagram) API認証情報
# https://developers.facebook.com/apps/
# ============================================================
# Facebookページアクセストークン（Meta Business Suite → 設定 → APIアクセス）
META_PAGE_ACCESS_TOKEN=your_page_access_token

# FacebookページID（ページURL の数字部分）
FACEBOOK_PAGE_ID=your_page_id

# Instagram ビジネスアカウントID
# Meta Graph API: GET /me/accounts → instagram_business_account.id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_account_id

# ============================================================
# Web ダッシュボード認証（本番環境では必ず設定）
# ============================================================
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=your_secure_password

# ============================================================
# データベース（オプション: 未設定時はJSONファイルを使用）
# ============================================================
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
